{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "references": [
    { "path": "core" },
    { "path": "packages/login-widget" },
    { "path": "apps/login-app" }
  ],
  "exclude": ["node_modules", "packages", "apps", "e2e", "core"]
}

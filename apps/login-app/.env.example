# === Required: ForgeRock AM Connection ===
VITE_FR_AM_URL=https://your-tenant.forgeblocks.com/am
VITE_FR_AM_COOKIE_NAME=iPlanetDirectoryPro
VITE_FR_REALM_PATH=alpha
VITE_FR_OAUTH_PUBLIC_CLIENT=your-oauth-client-id

# === Required: BFF Cookie Encryption ===
# AES-256-GCM key for encrypting auth state cookies. Must be >= 32 characters.
# Generate with: openssl rand -base64 32
COOKIE_SECRET=

# === Required: SvelteKit adapter-node CSRF ===
# The public URL users access (scheme + host + port).
# adapter-node rejects requests where Origin != this value.
ORIGIN=http://localhost:3000

# === Optional: Tuning ===
# COOKIE_TTL_SECONDS=300    # Cookie Max-Age in seconds (default: 300)
# APP_DOMAIN=localhost       # Cookie domain (default: localhost)
# AM_REQUEST_TIMEOUT=30000  # AM HTTP timeout in ms (default: 30000)

# === Optional: Logging ===
# LOG_FORMAT=pretty                        # "json" | "pretty" | "logfmt" (default: "pretty")
# LOG_LEVEL=Info                           # Debug | Info | Warning | Error | Fatal (default: "Info")

# === Optional: OpenTelemetry ===
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318   # OTLP collector URL (unset = OTel disabled)
# OTEL_SERVICE_NAME=login-bff                          # OTel service name (default: "login-bff")

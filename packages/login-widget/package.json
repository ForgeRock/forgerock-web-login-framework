{
  "name": "@forgerock/login-widget",
  "version": "1.3.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./widget.css": "./dist/widget.css",
    "./iife": {
      "default": "./dist/widget.iife.js"
    }
  },
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/widget.iife.js",
  "jsdelivr": "./dist/widget.iife.js",
  "files": ["dist"],
  "repository": {
    "url": "https://github.com/forgerock/forgerock-web-login-framework.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org"
  },
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "build:types": "svelte-package -o svelte-package",
    "build:iife": "vite build --config vite.config.iife.ts",
    "build:release": "pnpm run build && pnpm run build:iife && pnpm run build:types && node scripts/copyTypes.mjs && node scripts/processTypes.mjs",
    "test": "vitest"
  },
  "dependencies": {
    "@forgerock/javascript-sdk": "^4.4.2",
    "@forgerock/ping-protect": "^4.4.2",
    "qrcode": "1.5.3",
    "xss": "1.0.14",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@hcaptcha/types": "^1.0.3",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-links": "^10.1.11",
    "@storybook/svelte": "^10.1.11",
    "@storybook/sveltekit": "^10.1.11",
    "@storybook/test-runner": "^0.24.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@types/qrcode": "1.5.5",
    "@vitest/ui": "^3.2.4",
    "@vueless/storybook-dark-mode": "^10.0.4",
    "axe-playwright": "^2.2.2",
    "autoprefixer": "^10.4.17",
    "babel-loader": "^9.1.2",
    "chromatic": "^10.9.1",
    "playwright": "^1.44.0",
    "postcss": "^8.5.8",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^15.0.0",
    "storybook": "^10.1.11",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.5",
    "svelte-loader": "^3.2.4",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^3.3.3",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  }
}
